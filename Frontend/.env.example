# Landing Page Environment Variables
# For Vercel deployment - add these to your Vercel project settings

# Landing Only Mode - disables SaaS routes
VITE_LANDING_ONLY=true

# Cal.com booking link (your Cal.com username/event)
VITE_CAL_LINK=seeker/30min

# Contact information
VITE_CONTACT_PHONE=01211100767
VITE_CONTACT_EMAIL=team@seekersai.org

# Waitlist form endpoint (Formspree)
VITE_WAITLIST_ENDPOINT=https://formspree.io/f/xlglrdzp
