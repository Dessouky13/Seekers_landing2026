# Landing Page Environment Variables
# For Vercel deployment - add these to your Vercel project settings

# Landing Only Mode - disables SaaS routes
VITE_LANDING_ONLY=true

# Contact information
VITE_CONTACT_PHONE=01044332566
VITE_CONTACT_EMAIL=team@seekersai.org

# Public site URL (used for SEO canonical/OG + sitemap)
VITE_SITE_URL=https://www.seekersai.org

# Contact-form endpoint — point this at your n8n WhatsApp webhook (Production URL).
# The form POSTs JSON: { name, email, company, phone, size, service, message, source, submittedAt }
# Make sure the n8n Webhook node has CORS "Allowed Origins" set to your domain (or *).
VITE_CONTACT_ENDPOINT=https://your-n8n-host/webhook/seekers-contact

# Optional fallback if VITE_CONTACT_ENDPOINT is not set (Formspree form)
VITE_WAITLIST_ENDPOINT=https://formspree.io/f/xlglrdzp
